<?page title="" contentType="text/html;charset=UTF-8"?>
<zk xmlns:n="clien">
<window id="wndOpcionMenu" title="" border="none" use="pe.itsb.vyrbus.view.ctrl.WndOpcionMenu" >
	<div id="divLista">
		<listbox id="listboxLista" rows="16"  onSelect="">
			<listhead sizable="true">
				<listheader width="35px" label="#" style="color: #ffffff;" />
				<listheader label="MENU PADRE" sort="auto" style="color: #ffffff;"/>
				<listheader label="MENU" sort="auto" style="color: #ffffff;"/>
				<listheader label="NOMBRE DEL OBJETO" sort="auto" style="color: #ffffff;"/>
				<listheader label="URL" sort="auto" style="color: #ffffff;"/>
				<listheader label="ORDEN" sort="auto" width="50px" style="color: #ffffff;" />
				<listheader label="ESTADO" sort="auto" style="color: #ffffff;"/>
			</listhead>
		</listbox>
	</div>
	
	
	
	
	<div id="divMantenimiento">
		<groupbox closable="false" mold="3d" >
		<caption label="OPCION MENÚ" style="color: #ffffff;"/>
			<grid id="grmante" style="border:none">
				<columns>
 					<column width="100px" align="right" /> 
 					<column width="230px" />
 					<column width="140px" align="right"/>
				</columns>
				<rows>
					<row>
<!-- 						<label value="TIPO MENU :"    /> -->
						<separator />	
						<div>
							<textbox id="textboxId" />
							<checkbox id="ckbMenuPadre" label="ES MENU PADRE ?" onCheck="wndOpcionMenu.onCheckEsMenuPadre()"/>
						</div>
						
						<label value="MUENU PADRE :"    />
						<combobox id="cmbOpcionMenuPadre" readonly="true"  width="225px" onOK="pe.itsb.vyrbus.service.util.Util.setFocus(txtDenominacion)"/>
					</row>
					<row>
						<label value="DENOMINACIÓN :" />
						<textbox id="txtDenominacion" maxlength="30" style="text-transform:none;font-size:12px!important" onOK="pe.itsb.vyrbus.service.util.Util.setFocus(txtNombreObjeto)"/>
						<label value="NOMBRE OBJETO :" />
						<textbox id="txtNombreObjeto"   maxlength="30" style="text-transform:none; font-size:12px!important" onOK="pe.itsb.vyrbus.service.util.Util.setFocus(txtUrl)"/>
					</row>
					<row>
						<label value="URL :" />
						<textbox id="txtUrl"   maxlength="100" style="text-transform:none; font-size:12px!important" onOK="pe.itsb.vyrbus.service.util.Util.setFocus(spOrden)" />			
						<label value="ORDEN OPCIÓN MENU :"    />
						<spinner  id="spOrden" onOK="pe.itsb.vyrbus.service.util.Util.setFocus(ckbHabilitado)" />					
					</row>
					<row>
						<separator></separator>
						<checkbox id="ckbHabilitado" label="HABILITADO" />
						<separator></separator><separator></separator>
					</row>
				</rows>
			</grid>
			
			
			
		</groupbox>
	</div>

</window>
</zk>