<window id="wndVentaReserva" border="none" use="com.cystesoft.vyrbus.view.ctrl.WndVentaReserva" >
	<tabbox>
		<tabs>
			<tab id="tabItinerario" label="Selección de Itinerario" onClick="wndVentaReserva.selectedTabItinerario()"/>
			<tab id="tabAsientos" label="Selección de Asientos" onClick="wndVentaReserva.selectedTabAsientos()"/>
			<tab id="tabVenta" label="Información de la Venta"/>
		</tabs>
		<tabpanels>
			<tabpanel><!-- SELECCION DE ITINERARIO -->
				<groupbox mold="3d" style="overflow:auto">
					<caption label="INFORMACION DE LA VENTA" style="color: #ffffff;"/>
					<grid>
						<columns>
							<column width="130px"/>
							<column width="110px"/>
							<column width="160px"/>
							<column />
						</columns>
						<rows>
							<row>
								<label value="TIPO DE OPERACION : " sclass="label-size11"/>
								<combobox id="cmbTipoOperacion" width="100px" readonly="true" onChange="wndVentaReserva.onSelectTipoOperacion()"/>
								<hlayout>
									<checkbox id="chkVentaRemota" label="Remota" onClick="wndVentaReserva.onSelectTipoVenta()"/>
									<checkbox id="chkBoletoPrepagado" label="Prepagado" onClick="wndVentaReserva.onSelectTipoVenta()" visible="false" disabled="true"/>
								</hlayout>
								<cell rowspan="3" style="background:white; padding:0px">
									<groupbox id="grpVentaRemota" closable="false" mold="3d" width="400px" visible="false">
										<caption label="DATOS DE VENTA REMOTA" style="color: #ffffff;"/>
										<grid>
											<columns>
												<column align="right" width="100px"/>
											</columns>
											<rows>
												<row>
													<label value="AGENCIA REMOTA :" sclass="label-size9-bold"/>
													<combobox id="cmbAgenciaRemota" autodrop="true" width="270px" autocomplete="true"/>
												</row>
												<row>
													<label value="USUARIO REMOTO :" sclass="label-size9-bold"/>
													<combobox id="cmbUsuarioRemoto" autodrop="true" width="270px"/>
												</row>
												<row>
													<label value="COMPROBANTE :" sclass="label-size9-bold"/>
													<radiogroup>
														<hlayout>
															<radio id="rdPrepagadoRemoto" label="PREPAGADO" style="font-size:9px !important;font-weight: bold;color:blue;"/>
															<separator/>
															<radio id="rdBoletoRemoto" label="BOLETO VIAJE" style="font-size:9px !important;font-weight: bold;color:blue"/>
															<separator/>
															<radio id="rdElectronicoRemoto" label="ELECTRONICO" style="font-size:9px !important;font-weight: bold;color:blue" disabled="true"/>
														</hlayout>
													</radiogroup>
												</row>
 												<row visible="false">
 													<label value="COMPROBANTE :" sclass="label-size9-bold"/>
 													<bandbox id="bndbxUsuarioHardware" mold="rounded" autodrop="true" width="270px" disabled="true" style="font-size:9px">
 														<bandpopup>
 															<listbox id="lbxUsuarioHardware" width="261px">
 																<listhead>
  																	<listheader label="COMPROBANTE" width="110px" style="color: #ffffff;"/>
 																	<listheader label="SERIE" width="50px" align="center" style="color: #ffffff;"/>
 																	<listheader label="CORRELATIVO" width="100px" align="center" style="color: #ffffff;"/>
 																</listhead>
 															</listbox>
 														</bandpopup>
 													</bandbox>
 												</row>
											</rows>
										</grid>
									</groupbox>	
								</cell>
							</row>
							<row spans="3">
								<radiogroup>
									<radio id="rdVentaNormal" label="Venta Normal" selected="true" onCheck="wndVentaReserva.onSelectTipoVenta()"/>
									<separator width="15px" orient="vertical"/>
									<radio id="rdVentaFechaAbierta" label="Venta a Fecha Abierta" onCheck="wndVentaReserva.onSelectTipoVenta()"/>
									<separator width="15px" orient="vertical"/>
									<radio id="rdVentaIdaVuelta" label="Venta Ida y Vuelta" onCheck="wndVentaReserva.onSelectTipoVenta()"/>											
								</radiogroup>
							</row>
							
							<row spans="3" style="background:#B4B4B4; padding:0px">
								<grid style="background:#B4B4B4; border:none;">
									<columns>
										<column width="70px" align="right"/>
										<column width="180px"/>
										<column/>
									</columns>
									<rows>
										<row style="background:#e0e0e0; border:none;">
											<label value="ORIGEN :" sclass="label-size11"/>
											<combobox id="cmbOrigen" autodrop="true" width="160px" onOK="cmbDestino.setFocus(true)"/>
											<cell rowspan="2">
												<button id="btnBuscarItinerario" sclass="btnCommandM" autodisable="self" label="Buscar" image="/resources/mp_buscarEnabled.png" onClick="wndVentaReserva.onBuscarItinerarios()"/>
											</cell>											
										</row>
										<row style="background:#e0e0e0; border:none;">
											<label value="DESTINO :" sclass="label-size11"/>
											<combobox id="cmbDestino" focus="true" onFocus="cmbDestino.select()" autodrop="true" width="160px" onOK="btnBuscarItinerario.setFocus(true)"/>
										</row>
									</rows>
								</grid>
							</row>
						</rows>
					</grid>
					
