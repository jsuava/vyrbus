													<columns>
														<column align="right" width="100px"/>
														<column align="left" width="125px"/>
														<column align="right" width="100px"/>
														<column align="left"/>
													</columns>
													<rows>
														<row>
															<label value="ORIGEN :"/>
															<label id="lblOrigenRetorno" sclass="label-size11-bold-blue"/>
															<label value="DESTINO :"/>
															<label id="lblDestinoRetorno" sclass="label-size11-bold-blue"/>
														</row>
														<row>
															<label value="PTO. EMBARQUE :"/>
															<combobox id="cmbPtoEmbarqueRetorno" width="115px" onChange="wndVentaReserva.onSelectPtoEmbarque(false)"/>
															<label value="AG. LLEGADA :"/>
															<combobox id="cmbPtoDesembarqueRetorno" width="130px" onChange="wndVentaReserva.onSelectPtoDesembarque(false)"/>
														</row>
														<row>
															<label value="FECHA PARTIDA :"/>
															<label id="lblFechaPartidaRetorno" sclass="label-size11-bold-blue"/>
															<label value="FECHA LLEGADA :"/>
															<label id="lblFechaLlegadaRetorno" sclass="label-size11-bold-blue"/>
														</row>
														<row>
															<label value="HORA PARTIDA :"/>
															<label id="lblHoraPartidaRetorno" sclass="label-size11-bold-blue"/>
															<label value="HORA LLEGADA :"/>
															<label id="lblHoraLlegadaRetorno" sclass="label-size11-bold-blue"/>
														</row>
														<row>
															<label value="NRO ASIENTO :"/>
															<label id="lblNroAsientoRetorno" sclass="label-size11-bold-blue"/>
															<hlayout>
																<label id="lblTarifaDenoRetorno" value="TARIFA :"/>
																<label id="lblTarifaDenoRetornoOtraMoneda" value="TARIFA :" visible="false"/>
																<label id="lblExpiracionReservaRetorno" value="RESERVA EXPIRA :" visible="false"/>
															</hlayout>										
															<hlayout>
																<label id="lblTarifaRetorno" sclass="label-size11-bold-blue"/>
																<datebox id="dtbxExpiracionReservaRetorno" width="125px" format="dd/MM/yyyy HH:mm:ss" readonly="true" visible="false" style="font-size:11px"/>
															</hlayout>
														</row>
														<row>
															<label id="lblBoletoRetorno" value="N° BOLETO :" style="text-align:center; color:blue; font-weight:bold; font-size:13px !important"/>
															<hlayout>
																<textbox id="txtNumeroBoletoRetorno" width="100px" readonly="true" style="text-align:center; color:blue; font-weight:bold; font-size:13px !important"/>
																<image id="imgRefreshBoletoRetorno" src="resources/mp_refrescarEnabled.png" style="cursor:pointer" visible="false" tooltiptext="Haga click aqui para refrescar el Número de Boleto"/>
															</hlayout>
															<label value="ALIMENTACION :"/>
															<combobox id="cmbAlimentacionRetorno" readonly="true" autodrop="true" width="125px"/>
														</row>
														<row spans="1,3">
															<label value="OBSERVACIONES :"/>
															<textbox id="txtObservacionesRetorno" multiline="true" height="30px" width="97%" maxlength="255"/>
														</row>
													</rows>								
												</grid>
											</tabpanel>
										</tabpanels>
									</tabbox>
										
									<vlayout>
										<separator height="22px" orient="vertical"/>
										<grid width="136px" sclass="grid-no-border">
											<columns>
												<column align="right"/>
											</columns>
											<rows>
												<row style="background:white">
													<label id="lblTotalPagarPreliminar" value="TOTAL A PAGAR S/." style="color:blue; font-size:14px; font-weight:bold" visible="false"/>
												</row>
												<row style="background:white">
													<button label="Grabar" 
															sclass="btnCommandL" 
															autodisable="self" 
															image="resources/mp_guardarEnabled.png"  
															onClick="wndVentaReserva.onGuardarVentaReserva()"  
															tooltiptext="Realiza el guardado de la Venta."/>									
												</row>
												<row style="background:white">
													<button label="Cancelar" 
															sclass="btnCommandL" 
															autodisable="self" 
															image="resources/mp_cancelarEnabled.png"  
															onClick="wndVentaReserva.selectedTabItinerario(); tabItinerario.setSelected(true)" 
															tooltiptext="Borra todo el proceso y regresa a la pestaña de Selección de itinerario."/>
												</row>
												<row style="background:white">
													<button label="Cerrar" 
															sclass="btnCommandL" 
															autodisable="self" 
															image="resources/mp_cerrarEnabled.png"  
															onClick="wndVentaReserva.liberarAsientos(); wndVentaReserva.closeTabWindow()" 
															tooltiptext="cierra la ventana de la Venta"/>
												</row>
											</rows>
										</grid>
									</vlayout>									
								</hlayout>

								<tabbox width="940px" >
									<tabs>
										<tab id="tabPasajero" label="Pasajero"/>
										<tab id="tabCliente" label="Cliente" />
										<tab id="tabPagos" label="Pagos" />
									</tabs>
									<tabpanels>
										<tabpanel width="930px"><!-- DATOS DEL PASAJERO -->
											<vlayout>
												<groupbox id="grpbxListaPasajeros" mold="3d" closable="false" visible="false">
													<caption label="LISTADO DE RESULTADOS" style="color: #ffffff;"/>
													<listbox id="lbxPasajeros" mold="paging" pageSize="5" width="500px">
														<listhead>
															<listheader label="#" width="30px" style="color: #ffffff;"/>
															<listheader label="DOCUMENTO" width="68px" style="color: #ffffff;"/>
															<listheader label="NUMERO" width="75px" style="color: #ffffff;"/>
															<listheader label="NOMBRES" style="color: #ffffff;"/>
															<listheader label="KMS" width="70px" align="right" style="color: #ffffff;"/>
														</listhead>
													</listbox>
												</groupbox>
												<groupbox mold="3d" closable="false">
												<caption label="INFORMACIÓN DEL PASAJERO" style="color: #ffffff;"/>
													<toolbar>
														<toolbarbutton id="tlbbtnNuevoPax" label="Nuevo" image="resources/toolbar/mp_toolbarNuevo.png" onClick="wndVentaReserva.onNewPax()"/>
														<toolbarbutton id="tlbbtnModificarPax" label="Modificar" image="resources/toolbar/mp_toolbarModificar.png" onClick="wndVentaReserva.onModifyPax()" disabled="true"/>
														<toolbarbutton id="tlbbtnLimpiarPax" label="Limpiar" image="resources/toolbar/mp_toolbarLimpiar.png" onClick="wndVentaReserva.onCleanControlsPax()"/>
														<toolbarbutton id="tlbbtnCancelarPax" label="Cancelar" image="resources/toolbar/mp_toolbarCancelar.png" onClick="wndVentaReserva.onCancelPax()" disabled="true"/>
														<toolbarbutton id="tlbbtnGuardarPax" autodisable = "self" label="Guardar" image="resources/toolbar/mp_toolbarGuardar.png" onClick="wndVentaReserva.onSavePax()" disabled="true"/>
													</toolbar>
													<grid >
														<columns>
															<column width="15%" align="right"/>
															<column width="25%"/>
															<column width="15%" align="right"/>
															<column width="30%"/>
															<column width="15%"/>
														</columns>
														<rows>
															<row sclass="background-gris">
																<label value="TIPO DOCUMENTO (*) :"/>
																<combobox id="cmbTipoDocumento" readonly="true" onOK="txtDocumentoPax.setFocus(true)" onChange="wndVentaReserva.habilitarNacionalidad()"/>
																<label value="NUMERO DOCUMENTO (*) :" style="color:blue; font-weight:bold" />
																<hbox align="center">
																	<textbox id="txtDocumentoPax" width="120px" onChange="wndVentaReserva.verificarPaxReniec()" maxlength="15"/>
																	<image id="imgValidacionDNI" height="13px" style="cursor:pointer" />
																</hbox>
																
																<cell rowspan="7" align="center" style="background:#F7F7F7">
																	<image id="imgPasajero" height="90px" width="90px"/>																														
																</cell>
															</row>
															<row sclass="background-gris">
																<label value="APELLIDO PATERNO (*) :" style="color:blue; font-weight:bold"/>
																<textbox id="txtApePat" width="140px" maxlength="30"/>
																<label value="APELLIDO MATERNO :" style="font-weight:bold" maxlength="30"/>
																<textbox id="txtApeMat" width="120px" maxlength="30" />
															</row>
															<row style="background:#F7F7F7" spans="1,3">
																<label value="NOMBRES (*) :" style="color:blue; font-weight:bold" maxlength="30"/>
																<textbox id="txtNombres" width="140px" maxlength="30"/>													
															</row>
															<row spans="1,3" style="background:#F7F7F7">
																<label value="DIRECCIÓN :"/>
																<textbox id="txtDireccionPax" width="75%" onOK="txtTelefono.setFocus(true)" maxlength="100"/>
															</row>
															<row style="background:#F7F7F7">
																<label value="TELÉFONO (*):"/>
																<textbox id="txtTelefono" onOK="btnUbigeoPax.setFocus(true)" maxlength="30" width="140px"/>
																<label value="UBIGEO (*) :" visible="false" />
																<hbox align="center" visible="false" >
																	<textbox id="txtUbigeoPax" width="170px" onOK="txtEmailPax.setFocus(true)"/>
																	<textbox id="txtUbigeoIdPax" visible="false"/>
																	<button id="btnUbigeoPax" sclass="btnImage" label="..."/>
																</hbox>
															</row>
															<row style="background:#F7F7F7">
																<label id="lblEmail" value="EMAIL :"/>
																<hlayout>
																	<textbox id="txtEmailPax" style="text-transform:none !important" onOK="dtbxFechaNacimiento.setFocus(true);" maxlength="50" width="140px"/>
																	<checkbox id="chbxNoTieneMail" label="No Tiene" checked="false" />
																</hlayout> 																
																<label value="FEC. NACIMIENTO"/>
																<datebox id="dtbxFechaNacimiento" format="dd/MM/yyyy" buttonVisible="false" width="120px" constraint="no future: No puede ingresar una fecha mayor a la de hoy." ></datebox>
<!--  																<hlayout valign="middle"> -->
<!--  																	<combobox id="cmbAnio" width="50px" autodrop="true" placeholder="1920" onOK="cmbMes.setFocus(true)" buttonVisible="false"/> -->
<!--  																	<label value="MES :"/> -->
<!--  																	<combobox id="cmbMes" width="80px" autodrop="true" placeholder="Enero" onOK="cmbDia.setFocus(true)"/> -->
<!--  																	<label value="DIA :"/> -->
<!--  																	<combobox id="cmbDia" width="50px" autodrop="true" placeholder="01" onOK="cmbSexo.setFocus(true)"/> -->
<!--  																</hlayout>																										  -->
															</row>															
															<row style="background:#F7F7F7">
																<label value="SEXO (*) :"/>
																<combobox id="cmbSexo" readonly="true" onOK="ntbxEdad.setFocus(true)"/>
																<label value="EDAD (*) :"/>
																<intbox id="ntbxEdad" width="20px" style="font-size:9px"/>
															</row>
															<row id="rowNacionalidad" visible="false">
																<label value="NACIONALIDAD (*) :"/>
																<combobox id="cmbNacionalidad" readonly="true"/>
																<label/>
																<label/>
																<label/>
															</row>
															<row id="rowAdicional" visible="false" spans="5">
																<div align="left">
																<vbox width="100%">
																	<label id="lblInformativo1" sclass="label-size12-bold-alert"/>
																	<label id="lblInformativo2" style="color:red; font-size:13px !important; font-weight:bold"/>
																	<hbox spacing="0px">
																		<hlayout valign="middle">
																			<label id="lblInformativo3" maxlength="60" sclass="label-size11-bold-alert"/>
																			<image id="imgFidelizarPasajero" visible="false" tooltiptext="Haga click aqui para realizar la fidelización del Cliente y convertirlo en Pasajero Frecuente." style="cursor:pointer" />
																		</hlayout>
																		<image id="imgDetalleMotivo" src="/resources/mp_information.png" sclass="cursor-button" visible="false">
																			<attribute name="onClick">
																				Window wnd = new Window("VYRBUS", "normal", false);
																				Caption caption = new Caption("Information","/resources/mp_information.png");
																				wnd.setPosition("center:center");
																				wnd.appendChild(caption);
																				Vbox vbox = new Vbox();
																				vbox.setAlign("center");															
																				Textbox txtInformation = new Textbox(lblInformativo3.getValue());
																				txtInformation.setMultiline(true);
																				txtInformation.setWidth("324px");
																				txtInformation.setHeight("80px");
																				txtInformation.setReadonly(true);
																				Button btnClose = new Button("Cerrar", "/resources/mp_cerrarEnabled.png");
																				btnClose.setClass("btnCommandL");
																				btnClose.addEventListener("onClick", new org.zkoss.zk.ui.event.EventListener(){
																					public void onEvent(Event e){
																						wnd.onClose();
																					}
																				});
																				vbox.appendChild(txtInformation);
																				vbox.appendChild(btnClose);
																				wnd.appendChild(vbox);
																				wndVentaReserva.appendChild(wnd);
																				wnd.onModal();
																			</attribute>
																		</image>
																	</hbox>
																</vbox>
																</div>																		
															</row>											
														</rows>
													</grid>
												</groupbox>
											</vlayout>
										</tabpanel>
										<tabpanel width="930px"><!-- DATOS DEL CLIENTE -->
											<vlayout>
												<hlayout>
													<groupbox id="grpbxListaClientes" mold="3d" closable="false" visible="false">
														<caption label="LISTADO DE CLIENTES" style="color: #ffffff;"/>										
														<listbox id="lbxClientes" mold="paging" pageSize="5" width="500px">
															<listhead>
																<listheader label="#" width="30px" style="color: #ffffff;"/>
																<listheader label="DOCUMENTO" width="75px" style="color: #ffffff;"/>
																<listheader label="RAZON SOCIAL" style="color: #ffffff;"/>
																<listheader label="CONTACTO" width="130px" style="color: #ffffff;"/>
															</listhead>
														</listbox>
													</groupbox>
												</hlayout>
												<groupbox mold="3d">
													<caption label="INFORMACIÓN DEL CLIENTE" style="color: #ffffff;"/>
													<toolbar>
														<toolbarbutton id="tlbbtnNuevoClient" label="Nuevo" image="resources/toolbar/mp_toolbarNuevo.png" onClick="wndVentaReserva.onNewClient()"/>
														<toolbarbutton id="tlbbtnModificarClient" label="Modificar" image="resources/toolbar/mp_toolbarModificar.png" onClick="wndVentaReserva.onModifyClient()" disabled="true"/>
														<toolbarbutton id="tlbbtnLimpiarClient" label="Limpiar" image="resources/toolbar/mp_toolbarLimpiar.png" onClick="wndVentaReserva.onCleanControlsClient()"/>
														<toolbarbutton id="tlbbtnCancelarClient" label="Cancelar" image="resources/toolbar/mp_toolbarCancelar.png" onClick="wndVentaReserva.onCancelClient()" disabled="true"/>
														<toolbarbutton id="tlbbtnGuardarClient" autodisable = "self" label="Guardar" image="resources/toolbar/mp_toolbarGuardar.png" onClick="wndVentaReserva.onSaveClient()" disabled="true"/>
													</toolbar>
													<grid sclass="grid-no-border">
														<columns>
															<column width="15%" align="right"/>
															<column width="35%"/>
															<column width="15%" align="right"/>
															<column width="35%"/>											
														</columns>
														<rows>
															<row spans="1,1,2">
																<label value="RUC (*) :" style="color:blue; font-weight:bold"/>
																<textbox id="txtDocumentoCliente" width="120px" maxlength="11"/>
																<label id="lblDescuento" value="CLIENTE CREDITO / DESCUENTO CORPORATIVO" sclass="label-size12-bold-alert"/>
															</row>
															<row>
																<label value="RAZON SOCIAL (*) :" style="color:blue; font-weight:bold" maxlength="100"/>
																<textbox id="txtRazonSocial" width="90%"/>													
																<label value="CONTACTO :"/>
																<textbox id="txtContactoCliente" onOK="txtDireccionCliente.setFocus(true)" maxlength="50"/>
															</row>
															<row >
																<label value="DIRECCIÓN :"/>
																<textbox id="txtDireccionCliente" width="90%" onOK="ibxCantidadTrabajadores.setFocus(true)" maxlength="100"/>
																<label visible="false" value="CANTIDAD TRABAJADORES :"/>
																<intbox visible="false" id="ibxCantidadTrabajadores" width="100px" onOK="txtTelefonoClienteOne.setFocus(true)"/>
															</row>
															<row>
																<label value="TELÉF.1 :"/>
																<hbox align="center">
																	<textbox id="txtTelefonoClienteOne" width="135px" onOK="txtTelefonoClienteTwo.setFocus(true)" maxlength="10"/><separator width="5px" />
																	<label value="TELÉF.2 :"/>
																	<textbox id="txtTelefonoClienteTwo" width="134px" onOK="txtRubro.setFocus(true)" maxlength="10"/>
																</hbox>
																<label value="RUBRO :"/>
																<textbox id="txtRubro" onOK="txtEmailCliente.setFocus(true)" maxlength="80"/>
															</row>
															<row>
																<label value="EMAIL :"/>
																<textbox id="txtEmailCliente" style="text-transform:none !important" onOK="btnUbigeoCliente.setFocus(true)" maxlength="50"/>
																<label value="UBIGEO (*) :" visible="false" />
																<hbox align="center" width="100%" visible="false" >
																	<textbox id="txtUbigeoCliente" width="170px" readonly="true"/>
																	<textbox id="txtUbigeoIdCliente" visible="false"/>
																	<button id="btnUbigeoCliente" sclass="btnImage" label="..."/>
																</hbox>
															</row>
															<row>
																<label id="lblGrupoCentroCosto" value="GRUPO CENTRO COSTO :" visible="false"/>
																<combobox id="cmbGrupoCentroCosto" width="150px" readonly="true" visible="false" style="font-size:9px"/>
																<label id="lblCentroCosto" value="CENTRO COSTO :" visible="false"/>
																<combobox id="cmbCentroCosto" width="200px" visible="false" style="font-size:9px"/>													
															</row>
														</rows>
													</grid>
												</groupbox>
											</vlayout>
										</tabpanel>
										<tabpanel width="930px"><!-- PAGOS -->
											<vlayout>
												<grid width="930px" style="border:none;">
													<columns>
														<column align="right" width="15%"/>
														<column align="left" width="19%"/>
														<column align="right" width="15%"/>
														<column align="left" width="18%"/>
														<column align="right" width="15%"/>
														<column align="left" width="18%"/>
													</columns>
													<rows>
														<row>
			 												<label value="TIPO MONEDA :"/>
			 												<combobox id="cmbTipoMoneda" disabled="true" readonly="true" onChange="wndVentaReserva.validarOtraMoneda()"/>
															<label value="TIPO COMPROBANTE :"/>
															<combobox id="cmbTipoComprobante" readonly="true"/>
															<label value="FORMA PAGO :"/>
															<combobox id="cmbFormaPago" readonly="true" onChange="wndVentaReserva.onLoadTipoFormaPago()"/>															
														</row>
														<row>
															<label value="TARIFA :"/>
															<hlayout>
																<doublebox id="dblTarifa" width="66px" format="###,##0.00" readonly="true"/>
																<doublebox id="dblTarifaOtraMoneda" width="66px" format="###,##0.00" readonly="true" visible="false"/>
																<doublebox id="dblTarifaRetorno" format="##0.00" visible="false"/>
																<doublebox id="dblTarifaRetornoOtraMoneda" width="66px" format="###,##0.00" readonly="true" visible="false"/>
															</hlayout>
															<label value="TIPO FORMA PAGO :"/>
															<combobox id="cmbTipoFormaPago" readonly="true" disabled="true" onChange="wndVentaReserva.onValidateTipoFormaPago()"/>
															<label value="OPERADOR TARJETA :"/>
															<combobox id="cmbOperadorTarjetaCredito" readonly="true" disabled="true" onChange="wndVentaReserva.onLoadTarjetas()"/>
														</row>
														<row>
															<label value="RECARGO :"/>
															<doublebox id="dblRecargo" width="66px" format="###,##0.00" readonly="true"/>
															<label value="TARJETA CREDITO :"/>
															<combobox id="cmbTarjetaCredito" readonly="true" disabled="true"/>
															<label value="NUMERO OPERACION :"/>
															<textbox id="txtOperacionBancaria" mold="default" disabled="true" width="90px" maxlength="15"/>															
														</row>
														<row>
															<label value="DESCUENTO :"/>
															<hlayout>
																<doublebox id="dblDescuento" width="66px" format="###,##0.00" readonly="true"/>
																<doublebox id="dblDescuentoOtraMoneda" width="66px" format="###,##0.00" readonly="true" visible="false"/>
																<doublebox id="dblDescuentoRetorno" format="##0.00" visible="false" readonly="true"/>
																<doublebox id="dblDescuentoRetornoOtraMoneda" width="66px" format="###,##0.00" readonly="true" visible="false"/>
																<textbox id="txtIdPromocion" visible="false"/>
																<image id="imgPromocion" src="resources/mp_promocion.png" style="cursor:pointer" tooltiptext="Seleccionar promoción"/>
																<image id="imgQuitarPromocion" src="resources/mp_quitarPromocion.png" visible="false" style="cursor:pointer" tooltiptext="Quitar promoción"/>
															</hlayout>
															
															<button id="btnAdd" 
																	image="/resources/mp_nuevoEnabled.png"   
																	onClick="wndVentaReserva.AddFilaGastoXBuss(false)" 
																	sclass="btnImage" 
																	tooltiptext="Insertar nuevo Item" 
																	visible="false" />
															<button id="btnDelete"
																	image="/resources/mp_cerrar.png" 
																	sclass="btnImage" 
																	tooltiptext="Eliminar  Item"
																	visible="false" />
															<label value="MONTO PARCIAL:" visible="false"/>
															<doublebox id="dblMontoDetalleMixto" format="##0.00" visible="false" readonly="true"/>		
															
	
														</row>
														<row>
															<label value="IMPORTE :"/>
															<hlayout>
																<doublebox id="dblImporte" width="66px" onFocus="dblImporte.select()" format="###,##0.00" readonly="true"/>
																<doublebox id="dblImporteOtraMoneda" width="66px" format="###,##0.00" readonly="true" visible="false"/>
																<checkbox id="chkPagoMixto" label="Pago Mixto" onClick="wndVentaReserva.habilitarPagoMixto()"/>
															</hlayout>
															<cell rowspan="3" colspan="4" align="center" style="background:#F7F7F7" >
																<listbox id="listTipoPago" rows="2" visible="false">
																	<listhead sizable="false">
																		<listheader label="#" width="25px" style="color: #ffffff;"/>
																		<listheader label="TIPO FORMA PAGO" width="160px" align="left" style="color: #ffffff;"/>
																		<listheader label="OPERADOR TARJETA" width="140px"  align="left" style="color: #ffffff;"/>
																		<listheader label="TARJETA" width="170px"  align="left" style="color: #ffffff;"/>
																		<listheader label="IMPORTE" width="100px"  align="right" style="color: #ffffff;"/>
																	</listhead>
																</listbox>
															</cell>															
														</row>
														<row>
															<label id="lblImporteEfectivo" value="IMPORTE EFECTIVO :" visible="false"/>
															<doublebox id="dblImporteEfectivo" width="66px" format="###,##0.00" visible="false"/>

														</row>
														<row>
															<label id="lblImporteTarjeta" value="IMPORTE TARJETA :" visible="false"/>
															<doublebox id="dblImporteTarjeta" width="66px" format="###,##0.00" visible="false"/>
															
														</row>
														<row spans="6">
															<div align="left">
																<label id="lblPromocion" style="font-size:12px !important;font-weight:bold;color:RED"/>
															</div>												
														</row>

													</rows>
												</grid>									
											</vlayout>
										</tabpanel>
									</tabpanels>
								</tabbox>
							</vlayout>
  							<div id="divLogOperadorPor2" visible="false">
								<vbox align="center" style="position: absolute;right:16px;top:60px;">
									<label value="OPERADO POR " style="padding: 0px;font-weight: bold;font-size:27px !important;color:red"  />
									<image id="imgLogoOperadorPor2"/>
								</vbox>
							</div> 
						</row>
					</rows>
				</grid>
			</tabpanel>
		</tabpanels>
	</tabbox>	
</window>
</zk>