<?page title="Ventas y Reservas" contentType="text/html;charset=UTF-8"?>
<zk  xmlns:c="client" xmlns="http://www.zkoss.org/2005/zul">
<style>
    .maxHeightLsbxBusqServicio .z-listbox-body {
	  height: 46vh;
      overflow: auto;
    }
</style>
<window id="wndVentaReservaNew" title="" border="none" width="970px" use="pe.itsb.vyrbus.view.ctrl.WndVentaReservaNew">
	<div id="divPaso_1">	
		<groupbox mold="3d" closable="false" style="overflow:auto">
			<caption label="RUTA" style="color: #ffffff;"/>
			<hbox align="top">
				<grid width="190px" style="border-left:none;border-top:none;border-bottom:none;margin-top:-4px;">
					<rows>		
						<row>
							<separator height="1px" />
						</row>			
						<row>
							<vbox align="start">
								<hbox align="center">
									<textbox id="txtBusqBy" onFocus="self.select();" style="font-size:13px !important" width="135px" placeholder="DNI/COMPROBANTE" />
									<button id="btnBusqBy" autodisable="self" image="/resources/mp_buscarEnabled.png" style="margin-left:2px" />
								</hbox>
								<separator width="100%" height="1px" style="border-top:1px solid" />				
								<grid width="180px">
									<columns><column label="TIPO OPERACION"/></columns>
									<rows>
										<row style="padding: 10px">
											<radiogroup>												 
												<radio id="rdBusqIda" label="IDA" checked="true" style="color:blue"/>
												<separator orient="vertical" width="15px"/>
												<radio id="rdBusqIdaVuelta" label="IDA Y VUELTA" style="color:blue"/>
												<separator/>
												<checkbox id="chbxBusqConfirmaconFA" label="CONFIRMACION F.A." disabled="true"/>
											</radiogroup>		
										</row>
									</rows>
								</grid>																
								<separator height="2px"/>
								<combobox id="cmbBusqOrigen" style="font-size:13px !important;font-weight:bold" placeholder="ORIGEN" width="92%" onFocus="self.select();"  autocomplete="true" autodrop="true" tooltiptext="Origen"/>						
							</vbox>
						</row>					
					</rows>				
				</grid>
				<grid width="149px" style="border-left:none;border-top:none;border-bottom:none;margin-top:-4px;">
					<rows>
						<row>
							<listbox id="ltbxBusqDestinos" height="151px" width="140px" tooltiptext="Destino"/>
						</row>
					</rows>
				</grid>
				<grid width="478px" style="border-left:none;border-top:none;border-bottom:none;margin-top:-4px;">
					<rows>
						<row>
							<vbox>
								<label value="FECHA DE IDA" sclass="label-size11" />
								<calendar id="clrBusqIda" height="133px"/>
														 
							</vbox>
							<vbox id="vboxCalendarVuelta">
								<label value="FECHA DE VUELTA" sclass="label-size11" />
								<calendar id="clrBusqIdaVuelta" height="133px"/>
							</vbox>
						</row>
					</rows>
				</grid>
				<grid style="border:none;;margin-top:-4px;">
					<rows>
						<row>
							<vbox align="center" style="padding-top:22px">
								<button id="btnBuscar" sclass="btnCommandM" width="120px" height="32px" autodisable="self" label="Buscar" image="/resources/mp_buscarEnabled.png" />
								<separator height="1px"/>
								<button id="btnBusqCancelar" sclass="btnCommandM" width="120px" height="32px" autodisable="self" label="Cancelar" image="resources/mp_cancelarEnabled.png" />
								<separator height="1px"/>
								<button id="btnBusqCerrar" onClick="wndVentaReservaNew.closeTabWindow();" sclass="btnCommandM" width="120px" height="32px" autodisable="self" label="Cerrar" image="resources/mp_cerrar.png" />
							</vbox>
						</row>
					</rows>
				</grid>
			</hbox>
