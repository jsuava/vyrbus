<?page title="new page title" contentType="text/html;charset=UTF-8"?>
<zk>
<style> 
	.btnCommand{
		cursor: pointer;
		font-size: 14px;
		background-color: #4285F4;
		color: #FFFFFF;
		border-width: 0px; 
		border-radius: 4px;
	}
	.btnCommand:hover{
		box-shadow: 0 12px 16px 0 rgba(0,0,0,0.24), 0 17px 50px 0 rgba(0,0,0,0.19);
	} 
</style>
<window id="wndLiquidacionBus" title="" border="none" use="pe.itsb.vyrbus.view.ctrl.WndLiquidacionBus" >
	<div 	id="divLista">
		<listbox id="listboxLista" rows="15">
			<listhead sizable="true">
				<listheader label="#" width="50px" style="color: #ffffff;"/>
				<listheader label="BUS" sort="auto" style="color: #ffffff;"/>
				<listheader label="ITINERARIO" sort="auto" style="color: #ffffff;"/>
				<listheader label="TOTAL" sort="auto" style="color: #ffffff;"/>
			</listhead>
		</listbox>	
	</div>
	
<div id="divMantenimiento" >
	<groupbox mold="3d" closable="false" width="766px" >
		<caption label="LIQUIDACION DEL BUS" style="color: #ffffff;"/>
		<grid>
			<columns>
				<column width="90px" align="right" />
				<column width="180px" />
				<column width="60px" align="right" />
<!-- 				<column width="180px" /> -->
			</columns>
			<rows>
				<row>
					<div>
						<label value="ITINERARIO (*) :" />
						<textbox id="textboxId" />
					</div>
					<hbox>
						<longbox id="lbitinerario" readonly="true" />
						<button id="btnBuscar" 
								image="/resources/mp_buscarEnabled.png"  
								label="" sclass="btnImage"  
								tooltiptext="Buscar Itinerario" />
					</hbox>
					
					<label value="BUS (*) :" />
					<combobox id="cmbBus" readonly="true" />
<!-- 					<separator></separator>
 					<separator></separator>  -->
					<hbox>
						<button id="btnAdd" 
								image="/resources/mp_nuevoEnabled.png"   
								onClick="wndLiquidacionBus.AddFilaGastoXBuss(false)" 
								sclass="btnImage" 
								tooltiptext="Insertar nuevo Item" />
						<button id="btnDelete"
								image="/resources/mp_cerrar.png" 
								sclass="btnImage" 
								tooltiptext="Eliminar  Item" />
					</hbox>					
				</row>

			</rows>
		</grid>
		
		<grid style="border:none" >
		<columns>
			<column width="754px"/>
			<column />
		</columns>
		<rows>
			<row>
				<listbox id="listGastosXBus" rows="6">
					<listhead sizable="false">
						<listheader label="#" width="25px" style="color: #ffffff;"/>
						<listheader label="TIPO DE GASTO" width="140px" align="center" style="color: #ffffff;"/>
						<listheader label="MONTO" width="80px"  align="center" style="color: #ffffff;"/>
						<listheader label="OPERACION" width="105px"  align="center" style="color: #ffffff;"/>
						<listheader label="FECHA OPERACION" width="110px"  align="center" style="color: #ffffff;"/>
						<listheader label="OBSERVACIONES" align="center" width="250px" style="color: #ffffff;"/>
						<listheader label=" " align="center" style="color: #ffffff;"/>
					</listhead>
				</listbox>				
			</row>
			<row>
				<grid >
					<columns>
						<column width="184px" align="right"/>
						<column />
					</columns>
					<rows>
						<row>
							<label value="Total" sclass="label-size11" />
							<doublebox id="dbTotal" format="##0.00" width="80px" />
						</row>					
					</rows>
				</grid>	
				
			</row>
		</rows>		
		</grid>
		
	</groupbox>
	
</div>	
	
</window>
</zk>