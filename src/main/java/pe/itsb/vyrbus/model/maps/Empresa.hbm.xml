<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
    <class name="pe.itsb.vyrbus.model.bean.Empresa" table="VRMEMPRESA" schema="VYRBUSME" >
        
        <id name="id" type="java.lang.Integer">
            <column name="EMPRESA_ID" precision="5" scale="0" />
            <generator class="sequence">
                <param name="sequence">SEQ_VRMEMPRESA_ID</param>
            </generator>
        </id>                
        <property name="razonSocial" type="java.lang.String">
            <column name="C_RAZSOC" length="100" not-null="true" >
            	
            </column>
        </property>
        <property name="nombreCorto" type="java.lang.String">
            <column name="C_NOMCOR" length="25">
                
            </column>
        </property>
        <property name="direccion" type="java.lang.String">
            <column name="C_DIRECCION" length="100" >
            	
            </column>
        </property>                
        <many-to-one name="tipoDocumento" class="pe.itsb.vyrbus.model.bean.TipoDocumento" fetch="select">
            <column name="TIPDOC_ID" precision="2" scale="0" not-null="true">
                
            </column>
        </many-to-one>      
        <property name="numeroDocumento" type="java.lang.String">
            <column name="C_NUMDOC" length="15" not-null="true">
                
            </column>
        </property>  
        <property name="repLegal" type="java.lang.String">
            <column name="C_REPLEG" length="100">
                
            </column>
        </property>
        <property name="sigla" type="java.lang.String">
            <column name="c_sigla" length="5">                
            </column>
        </property>
        <property name="logo" type="java.lang.String">
            <column name="c_logo" length="20">                
            </column>
        </property>                                                 
        
        <!-- 		BEGIN CAMPOS DE AUDITORIA	 	-->
        <property name="estadoRegistro" type="java.lang.String">
            <column name="C_ESTREG" length="1" not-null="true">
                
            </column>
        </property>
        <property name="fechaInsercion" type="java.util.Date">
            <column name="AUDFECINS" length="7">
                
            </column>
        </property>
        <property name="usuarioInsercion" type="java.lang.String">
            <column name="AUDUSUINS" length="30">
                
            </column>
        </property>
        <property name="ipInsercion" type="java.lang.String">
            <column name="AUDIPINSE" length="15">
                
            </column>
        </property>
        <property name="fechaModificacion" type="java.util.Date">
            <column name="AUDFECMOD" length="7">
                
            </column>
        </property>
        <property name="usuarioModificacion" type="java.lang.String">
            <column name="AUDUSUMOD" length="30">
                
            </column>
        </property>
        <property name="ipModificacion" type="java.lang.String">
            <column name="AUDIPMODI" length="15">                
            </column>
        </property>
        <!-- 		END CAMPOS DE AUDITORIA	 	-->
    </class>
</hibernate-mapping>
