<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN" "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
	<class name="pe.itsb.vyrbus.model.bean.Usuario" table="VRMUSUARIO" schema="VRDEMO">
		<id name="id" type="java.lang.Integer">
			<column name="USUARIO_ID" precision="10"/>
			<generator class="sequence">
				<param name="sequence">SEQ_VRMUSUARIO_ID</param>
			</generator>
		</id>
		<many-to-one name="personal" class="pe.itsb.vyrbus.model.bean.Personal" fetch="select">
			<column name="PERSONAL_ID" precision="8"/>
		</many-to-one>
		<many-to-one name="agencia" class="pe.itsb.vyrbus.model.bean.Agencia" >
        	<column name="AGENCIA_ID" precision="5" scale="0">
        		<comment>Agencia que realiza el registro del pasajero</comment>
        	</column>
        </many-to-one>
        <many-to-one name="usuarioHardware" class="pe.itsb.vyrbus.model.bean.UsuarioHardware">
        	<column name="USUHARD_ID" precision="5" scale="0">
        		<comment>Usuario Hardware asociado para el caso de personal ajeno a TEPSA</comment>
        	</column>
        </many-to-one>
        <property name="nombre" type="java.lang.String">
            <column name="C_NOMBRE" length="20" not-null="true" />
        </property>
        <property name="apellidoPaterno" type="java.lang.String">
            <column name="C_APEPAT" length="20" />
        </property>
        <property name="apellidoMaterno" type="java.lang.String">
            <column name="C_APEMAT" length="20" />
        </property>
        <property name="codigo" type="java.lang.String">
            <column name="C_CODIGO" length="10"/>
        </property>
        <property name="login" type="java.lang.String">
			<column name="C_LOGIN" length="20" not-null="true"/>
		</property>
		<property name="password" type="java.lang.String">
			<column name="C_PASSWORD" length="128" not-null="true"/>
		</property>
		<property name="tipoPassword" type="java.lang.Integer">
			<column name="N_TIPPAS" precision="1" scale="0" not-null="true"></column>
		</property>
		<property name="tipoSeguridad" type="java.lang.Integer">
			<column name="N_TIPSEG" precision="1" scale="0" not-null="true">
				<comment>Indica el nivel de seguridad 1: Seguridad con applet, 0: Sin applet.</comment>
			</column>
		</property>
		<property name="emailFuncionario" type="java.lang.String">
			<column name="C_EMAIL" length="70">
				<comment>Direccion de correo para funcionarios TEPSA, que no estan en planilla.</comment>
			</column>
		</property>
		<!-- 		BEGIN CAMPOS DE AUDITORIA	 	-->
        <property name="estadoRegistro" type="java.lang.String">
            <column name="C_ESTREG" length="1" not-null="true">
                <comment>Estado de registro A(Activo), I(Inactivo).</comment>
            </column>
        </property>
        <property name="fechaInsercion" type="java.util.Date">
            <column name="AUDFECINS" length="7">
                <comment>Fecha de insercion/modificacion.</comment>
            </column>
        </property>
        <property name="usuarioInsercion" type="java.lang.String">
            <column name="AUDUSUINS" length="30">
                <comment>Usuario de insercion/modificacion.</comment>
            </column>
        </property>
        <property name="ipInsercion" type="java.lang.String">
            <column name="AUDIPINSE" length="15">
                <comment>IP de insercion/modificacion.</comment>
            </column>
        </property>
        <property name="fechaModificacion" type="java.util.Date">
            <column name="AUDFECMOD" length="7">
                <comment>Fecha de insercion/modificacion.</comment>
            </column>
        </property>
        <property name="usuarioModificacion" type="java.lang.String">
            <column name="AUDUSUMOD" length="30">
                <comment>Usuario de insercion/modificacion.</comment>
            </column>
        </property>
        <property name="ipModificacion" type="java.lang.String">
            <column name="AUDIPMODI" length="15">
                <comment>IP de insercion/modificacion.</comment>
            </column>
        </property>
        <!-- 		END CAMPOS DE AUDITORIA	 	-->
	</class>
</hibernate-mapping>