package com.tepsa.sisvyr.model.dao.impl;

import java.util.ArrayList;
import java.util.List;
import java.util.TreeMap;

import com.tepsa.sisvyr.model.dao.TipoViaDAO;
import com.tepsa.sisvyr.model.bean.TipoVia;

/**
 *
 * @author jM
 * @since JDK1.6
 */
@SuppressWarnings("unchecked")
public class TipoViaDAOImpl extends GenericDAOImpl implements TipoViaDAO {

	/* (non-Javadoc)
	 * @see com.tepsa.sisvyr.dao.TipoViaDAO#buscarPorEstadoRegistro(java.lang.String)
	 */
	@Override
	public ArrayList<TipoVia> buscarPorEstadoRegistro(String estado, String criterioOrden) {
		return (ArrayList<TipoVia>) super.findByEstadoRegistro(TipoVia.class, estado, criterioOrden);
	}

	/* (non-Javadoc)
	 * @see com.tepsa.sisvyr.dao.TipoViaDAO#buscarPorX(java.util.TreeMap)
	 */
	@Override
	public ArrayList<TipoVia> buscarPorX(TreeMap<String, Object> criteriosBusqueda, List<String> criteriosOrdenar) {
		return (ArrayList<TipoVia>) super.findByX(TipoVia.class, criteriosBusqueda, criteriosOrdenar);
	}

	/* (non-Javadoc)
	 * @see com.tepsa.sisvyr.dao.TipoViaDAO#buscarPorId(java.lang.Long)
	 */
	@Override
	public TipoVia buscarPorId(Long id) {
		return (TipoVia) super.findById(TipoVia.class, id);
	}

	/* (non-Javadoc)
	 * @see com.tepsa.sisvyr.dao.TipoViaDAO#guardar(com.tepsa.sisvyr.domain.TipoVia)
	 */
	@Override
	public void guardar(TipoVia tipoVia) {
		super.save(tipoVia);
	}

	/* (non-Javadoc)
	 * @see com.tepsa.sisvyr.dao.TipoViaDAO#actualizar(com.tepsa.sisvyr.domain.TipoVia)
	 */
	@Override
	public void actualizar(TipoVia tipoVia) {
		super.update(tipoVia);
	}

	/* (non-Javadoc)
	 * @see com.tepsa.sisvyr.dao.TipoViaDAO#inactivar(java.lang.Long)
	 */
	@Override
	public void inactivar(Long id) {
		super.inactivate(TipoVia.class, id);
	}
}