package com.tepsa.sisvyr.view.ui;

import org.zkoss.zk.ui.event.Event;
import org.zkoss.zk.ui.event.EventListener;
import org.zkoss.zul.Bandbox;
import org.zkoss.zul.Button;
import org.zkoss.zul.Combobox;
import org.zkoss.zul.Datebox;
import org.zkoss.zul.Doublebox;
import org.zkoss.zul.Intbox;
import org.zkoss.zul.Messagebox;
import org.zkoss.zul.Textbox;
import org.zkoss.zul.Timebox;

import com.tepsa.sisvyr.service.util.Messages;

public class DlgMessage {
	public static final String NOMBREAPLICACION = Messages.getString("System.title");
	public static final int BTN_OK = Messagebox.OK;
	public static final int BTN_YESNO = Messagebox.YES | Messagebox.NO;
	public static final int BTN_DEFAULT_NO=Messagebox.NO;
	public static final int BTN_DEFAULT_YES=Messagebox.YES;
	
	/**
	 * Muestra mensaje de advertencia
	 * @param msg	: contenido del Mensaje
	 * @throws Exception
	 */
	public static void warning(String msg){
		Messagebox.show(msg, NOMBREAPLICACION+" ADVIERTE", BTN_OK, Messagebox.EXCLAMATION);
	}
	/**
	 * Muestra el mensaje de advertencia.
	 * @param msg			: Mensaje que se desea mostrar.
	 * @param receiveFocus	: Objeto que recibe el foco cuando sucede la advertencia.
	 */
	public static void warning(String msg, final Object receiveFocus){
		Messagebox.show(msg, NOMBREAPLICACION+" ADVIERTE", BTN_OK, Messagebox.EXCLAMATION, new EventListener<Event>() {
			public void onEvent(Event e){
				if(receiveFocus instanceof Textbox)
					((Textbox)receiveFocus).setFocus(true);
				else if(receiveFocus instanceof Combobox)
						((Combobox)receiveFocus).setFocus(true);
				else if(receiveFocus instanceof Datebox)
					((Datebox)receiveFocus).setFocus(true);
				else if(receiveFocus instanceof Doublebox)
					((Doublebox)receiveFocus).setFocus(true);
				else if(receiveFocus instanceof Button)
					((Button)receiveFocus).setFocus(true);
			}
		});
	}
	
	/**
	 * Muestra mensaje de interrogante
	 * @param msg	: Contenido del mensaje
	 * @throws Exception
	 */
	public static int question(String msg){
		return Messagebox.show(msg, NOMBREAPLICACION+" PREGUNTA", BTN_YESNO, Messagebox.QUESTION);
	}
	
	/**
	 * Muestra mensaje de información
	 * @param msg	: Contenido del mensaje
	 * @throws Exception
	 */
	public static void information(String msg){
		Messagebox.show(msg, NOMBREAPLICACION+" INFORMA", BTN_OK, Messagebox.INFORMATION);
	}	
	/**
	 * Muestra el mensaje de información.
	 * @param msg			: Mensaje que se desea mostrar.
	 * @param receiveFocus	: Objeto que recibe el foco despues que sucede el mensaje de informacion.
	 */
	public static void information(String msg, final Object receiveFocus){
		Messagebox.show(msg, NOMBREAPLICACION+" INFORMA", BTN_OK, Messagebox.INFORMATION, new EventListener<Event>() {
			public void onEvent(Event e){
				if(receiveFocus!=null){
					if(receiveFocus instanceof Textbox){
						((Textbox)receiveFocus).setFocus(true);
						((Textbox)receiveFocus).select();
					}else if(receiveFocus instanceof Combobox){
							((Combobox)receiveFocus).setFocus(true);
							((Combobox)receiveFocus).select();
					}else if(receiveFocus instanceof Datebox)
						((Datebox)receiveFocus).setFocus(true);
					else if(receiveFocus instanceof Doublebox){
						((Doublebox)receiveFocus).setFocus(true);
						((Doublebox)receiveFocus).select();
					}else if(receiveFocus instanceof Intbox){
						((Intbox)receiveFocus).setFocus(true);
						((Intbox)receiveFocus).select();
					}else if(receiveFocus instanceof Button)
						((Button)receiveFocus).setFocus(true);
				   else if (receiveFocus instanceof Bandbox)
						((Bandbox)receiveFocus).setFocus(true);
				   else if (receiveFocus instanceof Timebox){
						((Timebox)receiveFocus).setFocus(true);
						((Timebox)receiveFocus).select();
				   }
				}
			}
		});
	}
	
	/**
	 * Muestra mensaje de error
	 * @param msg	: Contenido del mensaje
	 * @throws Exception
	 */
	public static void error(String msg){
		Messagebox.show(msg, NOMBREAPLICACION+" REPORTA UN ERROR", BTN_OK, Messagebox.ERROR);
	}
	/**
	 * Muestra el mensaje de error.
	 * @param msg			: Mensaje que se desea mostrar.
	 * @param receiveFocus	: Objeto que recibe el foco despues que sucede el mensaje de error.
	 */
	public static void error(String msg, final Object receiveFocus){
		Messagebox.show(msg, NOMBREAPLICACION+" INFORMA", BTN_OK, Messagebox.INFORMATION, new EventListener<Event>() {
			public void onEvent(Event e){
				if(receiveFocus instanceof Textbox)
					((Textbox)receiveFocus).setFocus(true);
				else if(receiveFocus instanceof Combobox)
						((Combobox)receiveFocus).setFocus(true);
				else if(receiveFocus instanceof Datebox)
					((Datebox)receiveFocus).setFocus(true);
				else if(receiveFocus instanceof Doublebox)
					((Doublebox)receiveFocus).setFocus(true);
				else if(receiveFocus instanceof Button)
					((Button)receiveFocus).setFocus(true);
			}
		});
	}
}
