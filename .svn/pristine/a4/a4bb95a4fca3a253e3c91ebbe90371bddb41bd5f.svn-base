	private Integer numeroPiso;
	private Date fechaBloqueo;
	private Date fechaExpiracionBloqueo;
	
	

	/**
	 * @return the ocupacionAsientosDesbloqueadosID
	 */
	public OcupacionAsientosDesbloqueadosID getOcupacionAsientosDesbloqueadosID() {
		return ocupacionAsientosDesbloqueadosID;
	}
	/**
	 * @param ocupacionAsientosDesbloqueadosID the ocupacionAsientosDesbloqueadosID to set
	 */
	public void setOcupacionAsientosDesbloqueadosID(
			OcupacionAsientosDesbloqueadosID ocupacionAsientosDesbloqueadosID) {
		this.ocupacionAsientosDesbloqueadosID = ocupacionAsientosDesbloqueadosID;
	}
	/**
	 * @return Objeto usuarioHardware.
	 */
	public UsuarioHardware getUsuarioHardware() {
		return usuarioHardware;
	}
	/**
	 * @param usuarioHardware	: Setea el objeto usuarioHardware.
	 */
	public void setUsuarioHardware(UsuarioHardware usuarioHardware) {
		this.usuarioHardware = usuarioHardware;
	}
	
	/**
	 * @return Objeto usuario.
	 */
	public Usuario getUsuario() {
		return usuario;
	}
	/**
	 * @param usuario	: Setea el objeto usuario.
	 */
	public void setUsuario(Usuario usuario) {
		this.usuario = usuario;
	}
	
