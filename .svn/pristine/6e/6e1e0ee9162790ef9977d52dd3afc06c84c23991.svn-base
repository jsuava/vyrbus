<?page title="" contentType="text/html;charset=UTF-8"?>
<zk>
<window title="" use="com.tepsa.sisvyr.view.ctrl.WndEstadoBus">
<div id="divLista">
	<listbox id="listboxLista">
		<listhead sizable="true">
			<listheader label="#" width="50px"/>
			<listheader label="DENIMINACION" sort="auto" />
			<listheader label="ESTADO" sort="auto" />
			<listheader label="COLOR" sort="auto" />
		</listhead>
	</listbox>
</div>

<div id="divMantenimiento">
	<groupbox mold="3d" closable="false">
		<caption label="Datos" />
		<grid>
			<columns>
				<column width="110px" align="right"/>
				<column width="240px" />
				<column width="90px" align="right"/>
			</columns>
			<rows>
				<row>
					<div>
						<label value="DENOMINACIÓN (*) :" />
						<textbox id="textboxId" />
					</div>
					<textbox id="txtDenominacion"  maxlength="20" onOK="cboTipoEstado.setFocus(true); cboTipoEstado.select()"/>
					<label value="TIPO ESTADO (*) :" />
					<combobox id="cboTipoEstado" readonly="true" onOK="txtColor.setFocus(true)" />
				</row>
				<row>
					<label value="COLOR :" />
					<textbox id="txtColor" maxlength="6" />
					<!-- <colorbox id="cbColor" /> -->
					<separator />
					<separator />
				</row>
			</rows>
		</grid>
	</groupbox>
</div>
</window>
</zk>