package com.tepsa.sisvyr.service.exceptions;

/**
 * @author Jose
 *
 */
public class IntervaloAsientosException extends Exception {
	private static final long serialVersionUID = 1L;
	public static final int INTERVALO_INICIAL = 1;
	public static final int INTERVALO_FINAL = 2;
	public static final int INTERVALO_INICIAL_MAYOR = 1;
	private int tipo;
	/**
	 * @return the tipo
	 */
	public int getTipo() {
		return tipo;
	}
	/**
	 * @param tipo the tipo to set
	 */
	public void setTipo(int tipo) {
		this.tipo = tipo;
	}
	public IntervaloAsientosException(int tipo) {
		super();
		this.tipo = tipo;
	}
	public IntervaloAsientosException() {
		super();
		// TODO Auto-generated constructor stub
	}
}
