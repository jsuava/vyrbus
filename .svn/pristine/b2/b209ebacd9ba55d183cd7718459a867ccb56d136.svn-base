package com.tepsa.sisvyr.service.business.impl;

import java.util.ArrayList;
import java.util.List;
import java.util.TreeMap;

import com.tepsa.sisvyr.model.bean.RolOpcionMenu;
import com.tepsa.sisvyr.model.bean.RolOpcionMenuID;
import com.tepsa.sisvyr.model.dao.RolOpcionMenuDAO;
import com.tepsa.sisvyr.model.dao.impl.GenericDAOImpl;

/**
 * 
 * @author José Abanto
 *
 */
@SuppressWarnings("unchecked")
public class RolOpcionMenuDAOImpl extends GenericDAOImpl implements RolOpcionMenuDAO {

	/*
	 * (non-Javadoc)
	 * @see com.tepsa.sisvyr.model.dao.RolOpcionMenuDAO#buscarPorEstadoRegistro(java.lang.String, java.lang.String)
	 */
	@Override
	public ArrayList<RolOpcionMenu> buscarPorEstadoRegistro(String estado,String criterioOrden) {
		return (ArrayList<RolOpcionMenu>) super.findByEstadoRegistro(RolOpcionMenu.class, estado, criterioOrden);
	}

	/*
	 * (non-Javadoc)
	 * @see com.tepsa.sisvyr.model.dao.RolOpcionMenuDAO#buscarPorX(java.util.TreeMap, java.util.List)
	 */
	@Override
	public ArrayList<RolOpcionMenu> buscarPorX(TreeMap<String, Object> criteriosBusqueda,List<String> criteriosOrdenar) {
		return (ArrayList<RolOpcionMenu>) super.findByX(RolOpcionMenu.class, criteriosBusqueda, criteriosOrdenar);
	}
	

	/*
	 * (non-Javadoc)
	 * @see com.tepsa.sisvyr.model.dao.RolOpcionMenuDAO#guardar(com.tepsa.sisvyr.model.bean.RolOpcionMenu)
	 */
	@Override
	public void guardar(RolOpcionMenu rolOpcionMenu) {
		super.save(rolOpcionMenu);
	}

	/*
	 * (non-Javadoc)
	 * @see com.tepsa.sisvyr.model.dao.RolOpcionMenuDAO#actualizar(com.tepsa.sisvyr.model.bean.RolOpcionMenu)
	 */
	@Override
	public void actualizar(RolOpcionMenu rolOpcionMenu) {
		super.update(rolOpcionMenu);
	}

	/*
	 * (non-Javadoc)
	 * @see com.tepsa.sisvyr.model.dao.RolOpcionMenuDAO#inactivar(com.tepsa.sisvyr.model.bean.RolOpcionMenuID, java.lang.String)
	 */
	@Override
	public void inactivarActivar(RolOpcionMenuID rolOpcionMenuID, String estado) {
		String Sql="UPDATE  vrtrol_opcmen rpm SET  rpm.c_estreg='"+estado+"', " +
					"rpm.audusumod='"+ rolOpcionMenuID.getUsuarioModificacion()+"', rpm.audipmodi='"+rolOpcionMenuID.getIpModificacion()+"' "+
					"WHERE rpm.rol_id="+rolOpcionMenuID.getIdRol()+" AND rpm.opcmen_id="+rolOpcionMenuID.getIdOpcionMenu();
					
		getSession().createSQLQuery(Sql).executeUpdate();
		
	}
	

}
