<?page title="new page title" contentType="text/html;charset=UTF-8"?>
<zk>
<window title="" border="none" use="com.tepsa.sisvyr.view.ctrl.WndDocumentoBus">
	
<div id="divLista">
	<listbox id="listboxLista">
		<listhead sizable="true">
			<listheader label="#" width="50px" />
			<listheader label="TIPO DOCUMENTO" sort="auto" />
			<listheader label="BUS" sort="auto" />
			<listheader label="ESTADO DOCUMENTO BUS" sort="auto" />
			<listheader label="NUMERO DOCUMENTO" sort="auto" />
			<listheader label="FECHA EXPEDICION" sort="auto" />
			<listheader label="FECHA VENCIMIENTO" sort="auto" />
		</listhead>
	</listbox>
</div>
<div id="divMantenimiento">
	<groupbox mold="3d" closable="false">
		<caption label="Datos del documento del Bus" />
		<grid>
			<columns>
				<column width="120px" align="right"/>
				<column width="190px" />
				<column width="115px" align="right"/>
			</columns>
			<rows>
				<row>
					<div>
						<label value="TIPO DOCUMENTO :" />
						<textbox id="textboxId" />
					</div>
					<combobox id="cboTipoDocumento" readonly="true" onOK="com.tepsa.sisvyr.service.util.Util.setFocus(cboBus)" />
					<label value="BUS :" />
					<combobox id="cboBus" readonly="true" onOK="com.tepsa.sisvyr.service.util.Util.setFocus(cboEstadoDocumento)" />
				</row>
				<row>
					<label value="ESTADO DOCUMENTO :" />
					<combobox id="cboEstadoDocumento" readonly="true" onOK="com.tepsa.sisvyr.service.util.Util.setFocus(txtnumeroDocumento)" />
					<label value="NÚMERO DOCUMENTO :" />
					<textbox id="txtnumeroDocumento"  maxlength="14" style="font-size:11px !important" onOK="com.tepsa.sisvyr.service.util.Util.setFocus(dbfechaExpedicion)"/>
				</row>
				<row>
					<label value="FECHA EXPRIRACIÓN :" />
					<datebox id="dbfechaExpedicion"  format="dd/MM/yyyy" width="130px" onOK="com.tepsa.sisvyr.service.util.Util.setFocus(dbfechaVencimiento)" />
					<label value="FECHA VENCIMIENTO :" />
					<datebox id="dbfechaVencimiento"   format="dd/MM/yyyy" />
				</row>
			</rows>
		</grid>
	</groupbox>
</div>


</window>
</zk>