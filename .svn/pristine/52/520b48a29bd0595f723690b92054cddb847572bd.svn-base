package com.tepsa.sisvyr.service.business.impl;

import java.util.List;

import org.springframework.transaction.annotation.Transactional;

import com.tepsa.sisvyr.model.bean.PuntosPasajeroFrecuente;
import com.tepsa.sisvyr.model.dao.PuntosPasajeroFrecuenteDAO;
import com.tepsa.sisvyr.service.business.PuntosPasajeroFrecuenteManager;

/**
 * @author Jose
 *
 */
public class PuntosPasajeroFrecuenteManagerImpl implements PuntosPasajeroFrecuenteManager {
	private PuntosPasajeroFrecuenteDAO puntosPasajeroFrecuenteDAO;

	/**
	 * @return the puntosPasajeroFrecuenteDAO
	 */
	public PuntosPasajeroFrecuenteDAO getPuntosPasajeroFrecuenteDAO() {
		return puntosPasajeroFrecuenteDAO;
	}
	/**
	 * @param puntosPasajeroFrecuenteDAO the puntosPasajeroFrecuenteDAO to set
	 */
	public void setPuntosPasajeroFrecuenteDAO(PuntosPasajeroFrecuenteDAO puntosPasajeroFrecuenteDAO) {
		this.puntosPasajeroFrecuenteDAO = puntosPasajeroFrecuenteDAO;
	}
	/* (non-Javadoc)
	 * @see com.tepsa.sisvyr.service.business.PuntosPasajeroFrecuenteManager#guardar(com.tepsa.sisvyr.model.bean.PuntosPasajeroFrecuente)
	 */
	@Override
	@Transactional
	public void guardar(PuntosPasajeroFrecuente puntosPasajeroFrecuente)throws Exception {
		getPuntosPasajeroFrecuenteDAO().guardar(puntosPasajeroFrecuente);
	}
	/* (non-Javadoc)
	 * @see com.tepsa.sisvyr.service.business.PuntosPasajeroFrecuenteManager#buscarXIDVenta(java.lang.Long)
	 */
	@Override
	public PuntosPasajeroFrecuente buscarXIDVenta(Long id) throws Exception {
		return getPuntosPasajeroFrecuenteDAO().buscarXIDVenta(id);
	}
	/* (non-Javadoc)
	 * @see com.tepsa.sisvyr.service.business.PuntosPasajeroFrecuenteManager#actualizar(com.tepsa.sisvyr.model.bean.PuntosPasajeroFrecuente)
	 */
	@Override
	@Transactional
	public void actualizar(PuntosPasajeroFrecuente puntosPasajeroFrecuente)throws Exception {
		getPuntosPasajeroFrecuenteDAO().actualizar(puntosPasajeroFrecuente);
	}
	/* (non-Javadoc)
	 * @see com.tepsa.sisvyr.service.business.PuntosPasajeroFrecuenteManager#buscarPuntosPaxFree(java.lang.Long)
	 */
	@Override
	public List<PuntosPasajeroFrecuente> buscarPuntosDisponibles(Long idPaxFree)throws Exception {
		return getPuntosPasajeroFrecuenteDAO().buscarPuntosDisponibles(idPaxFree);
	}
	/* (non-Javadoc)
	 * @see com.tepsa.sisvyr.service.business.PuntosPasajeroFrecuenteManager#actualizarPuntosCanjeados(java.lang.String, java.lang.String, java.lang.String)
	 */
	@Override
	public void actualizarPuntosCanjeados(String iDsVenta, String usuario, String ip, Long idVentaCanje) throws Exception {
		getPuntosPasajeroFrecuenteDAO().actualizarPuntosCanjeados(iDsVenta, usuario, ip,idVentaCanje);
	}
	/* (non-Javadoc)
	 * @see com.tepsa.sisvyr.service.business.PuntosPasajeroFrecuenteManager#buscarPuntosUtilizados(java.lang.String, java.lang.String)
	 */
	@Override
	public List<PuntosPasajeroFrecuente> buscarPuntosUtilizados(String idPaxFree, String fechaCanje) throws Exception {
		return getPuntosPasajeroFrecuenteDAO().buscarPuntosUtilizados(idPaxFree, fechaCanje);
	}
	/* (non-Javadoc)
	 * @see com.tepsa.sisvyr.service.business.PuntosPasajeroFrecuenteManager#buscaEstadoCuentaPaxFree(java.lang.Long, java.lang.String, java.lang.String)
	 */
	@Override
	public List<PuntosPasajeroFrecuente> buscaEstadoCuentaPaxFree(Long idPaxfree, String fechaInico, String fechaFin)throws Exception {
		return getPuntosPasajeroFrecuenteDAO().buscaEstadoCuentaPaxFree(idPaxfree, fechaInico, fechaFin);
	}
	/* (non-Javadoc)
	 * @see com.tepsa.sisvyr.service.business.PuntosPasajeroFrecuenteManager#restaurarPuntos(java.lang.Long)
	 */
	@Override
	public void restaurarPuntos(Long idVentaCaje) throws Exception {
		// TODO Auto-generated method stub
		getPuntosPasajeroFrecuenteDAO().restaurarPuntos(idVentaCaje);
	}
}
