package com.tepsa.sisvyr.service.exceptions;

import java.io.Serializable;

/**
 * @author Jose
 *
 */
public class PostergacionByTipoAgenciaNoPermitidoException extends Exception implements Serializable {
	private static final long serialVersionUID = 1L;
	private Integer tipoAgencia;
	
	public PostergacionByTipoAgenciaNoPermitidoException(Integer tipoAgencia) {
		super();
		this.tipoAgencia = tipoAgencia;
	}
	/**
	 * @return the tipoAgencia
	 */
	public Integer getTipoAgencia() {
		return tipoAgencia;
	}
	/**
	 * @param tipoAgencia the tipoAgencia to set
	 */
	public void setTipoAgencia(Integer tipoAgencia) {
		this.tipoAgencia = tipoAgencia;
	}
}
