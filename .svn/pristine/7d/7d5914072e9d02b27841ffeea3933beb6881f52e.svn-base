package com.tepsa.sisvyr.model.dao.impl;

import java.util.ArrayList;
import java.util.List;
import java.util.TreeMap;

import com.tepsa.sisvyr.model.dao.NumeroFlotaDAO;
import com.tepsa.sisvyr.model.bean.NumeroFlota;

/**
 *
 * @author jM
 * @since JDK1.6
 */
@SuppressWarnings("unchecked")
public class NumeroFlotaDAOImpl extends GenericDAOImpl implements NumeroFlotaDAO {

	/* (non-Javadoc)
	 * @see com.tepsa.sisvyr.dao.NumeroFlotaDAO#buscarPorEstadoRegistro(java.lang.String)
	 */
	@Override
	public ArrayList<NumeroFlota> buscarPorEstadoRegistro(String estado, String criterioOrden) {
		return (ArrayList<NumeroFlota>) super.findByEstadoRegistro(NumeroFlota.class, estado, criterioOrden);
	}

	/* (non-Javadoc)
	 * @see com.tepsa.sisvyr.dao.NumeroFlotaDAO#buscarPorX(java.util.TreeMap)
	 */
	@Override
	public ArrayList<NumeroFlota> buscarPorX(TreeMap<String, Object> criteriosBusqueda, List<String> criteriosOrdenar) {
		return (ArrayList<NumeroFlota>) super.findByX(NumeroFlota.class, criteriosBusqueda, criteriosOrdenar);
	}

	/* (non-Javadoc)
	 * @see com.tepsa.sisvyr.dao.NumeroFlotaDAO#buscarPorId(java.lang.Long)
	 */
	@Override
	public NumeroFlota buscarPorId(Long id) {
		return (NumeroFlota) super.findById(NumeroFlota.class, id);
	}

	/* (non-Javadoc)
	 * @see com.tepsa.sisvyr.dao.NumeroFlotaDAO#guardar(com.tepsa.sisvyr.domain.NumeroFlota)
	 */
	@Override
	public void guardar(NumeroFlota numeroFlota) {
		super.save(numeroFlota);
	}

	/* (non-Javadoc)
	 * @see com.tepsa.sisvyr.dao.NumeroFlotaDAO#actualizar(com.tepsa.sisvyr.domain.NumeroFlota)
	 */
	@Override
	public void actualizar(NumeroFlota numeroFlota) {
		super.update(numeroFlota);
	}

	/* (non-Javadoc)
	 * @see com.tepsa.sisvyr.dao.NumeroFlotaDAO#inactivar(java.lang.Long)
	 */
	@Override
	public void inactivar(Long id) {
		super.inactivate(NumeroFlota.class, id);
	}
}