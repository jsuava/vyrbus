<?page title="" contentType="text/html;charset=UTF-8"?>
<zk>
<window id="wndServicio" title="" use="com.tepsa.sisvyr.view.ctrl.WndServicio">
<div id="divLista">
	<listbox id="listboxLista">
		<listhead sizable="true">
			<listheader label="#" width="50px"/>
			<listheader label="DENOMINACIÓN" sort="auto" />
			<listheader label="NOMBRE CORTO (o sufijo)" sort="auto" />
			<listheader label="PISOS" sort="auto" />
			<listheader label="ASIENTOS" sort="auto" />
			<listheader label="NRO.FILAS" sort="auto" />
			<listheader label="NRO.COLUMNAS" sort="auto" />	
		</listhead>
	</listbox>
</div>

<div id="divMantenimiento" >
	<groupbox mold="3d" closable="false" >
		<caption label="DATOS DEL SERVICIO" />
		<grid>
			<columns>
				<column width="120px" align="right"/>
				<column width="170px"/>
				<column width="145px" align="right"/>
			</columns>
			<rows>
				<row>
					<div>
						<label value="DENOMINACIÓN (*) :" />
						<textbox id="textboxId" />
					</div>
					<textbox id="txtDenominacion" maxlength="20" width="150px" onOK="txtNombreCorto.setFocus(true)" />
					<label value="NOMBRE CORTO :" />
					<textbox id="txtNombreCorto" width="150px" maxlength="15" onOK="itPisos.setFocus(true)"/>
				</row>
				<row>
					<div>
						<label value="PISOS (*) :"   />
					</div>
					<intbox id="itPisos" maxlength="1" width="150px" onOK="itAsientos.setFocus(true)"/>
					<label value="ASIENTOS (*) :" />
				    <intbox id="itAsientos" maxlength="2" width="150px" onOK="itFilas.setFocus(true)"/>
				</row>
				<row>	
					<div>
						<label value="NÚMERO DE FILAS (*) :" />
					</div>
					<intbox id="itFilas" 	maxlength="2" width="150px" onOK="itColumnas.setFocus(true)" />
					<label value="CANTIDAD COLUMNNAS (*) :" />
					<intbox id="itColumnas" maxlength="2" width="150px" onOK="wndServicio.btnGuardar.setFocus(true)"/>	
				</row>
			</rows>
		</grid>
	</groupbox>
</div>
</window>
</zk>