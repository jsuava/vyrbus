	public void initComponents() {
		this.setTitle("Buscar Pasajero");
		this.setBorder("normal");
		this.setMaximizable(false);
		this.setMinimizable(false);
//		this.setSizable(false);
		this.setWidth("400px");
		this.setVisible(true);
		
		EventListener<Event> selectEventListener = new EventListener<Event>(){
			@SuppressWarnings("unchecked")
			public void onEvent(Event e) throws Exception{
				if(!(e.getTarget() instanceof Listbox && ((Listbox)e.getTarget()).getSelectedIndex() < 0)){
					if(lbxPasajeros.getSelectedIndex() > -1 && oEventListenerSelect !=null){
						//Valida si se trata de la busqueda de pasajero
						if(buscaPax){
							setIdPasajero(Long.valueOf(lbxPasajeros.getSelectedItem().getValue().toString()));
							setPasajero(ServiceLocator.getPasajeroManager().buscarPorId(getIdPasajero()));
						}else{
							//Cuando se  trata de la buqueda de clientes
							setCliente((Cliente)lbxPasajeros.getSelectedItem().getValue());
						}
						
						oEventListenerSelect.onEvent(new Event(com.tepsa.sisvyr.view.ui.Events.ON_SELECT));
						oThisWindow.onClose();
					}
				}
			}
		};
		
		Groupbox groupbox = new Groupbox();
		Caption caption = new Caption("Criterios de Busqueda");
//		groupbox.setMold("3d");
		groupbox.appendChild(caption);
		groupbox.setClosable(false);
		
		Grid grid = new Grid();
		Columns columns = new Columns();
		Column column = new Column();
		column.setWidth("32%");
		columns.appendChild(column);
		column = new Column();
		column.setWidth("68%");
		columns.appendChild(column);
		grid.appendChild(columns);
		
		Rows rows = new Rows();
		Row row = new Row();
		row.setSpans("2");
		
		Radiogroup radiogroup = new Radiogroup();
		rdPorDocumento= new Radio("Número Documento");
		rdPorDocumento.setSelected(true);
		rdPorDocumento.addEventListener(Events.ON_CHECK, new EventListener<Event>() {
			public void onEvent(Event e){
				habilitarDocumento();
				limpiar();				
			}
		});
		radiogroup.appendChild(rdPorDocumento);
		Space space = new Space();
		space.setWidth("30px");
		radiogroup.appendChild(space);
		rdPorNombres = new Radio("Nombres");
		rdPorNombres.addEventListener(Events.ON_CHECK, new EventListener<Event>() {
			public void onEvent(Event e){
				habilitarNombres();
				limpiar();
			}
		});
		radiogroup.appendChild(rdPorNombres);
		space = new Space();
		space.setWidth("30px");
		radiogroup.appendChild(space);
		Button button = new Button("Buscar");
		button.addEventListener(Events.ON_CLICK, new EventListener<Event>() {
			public void onEvent(Event e) throws Exception{
