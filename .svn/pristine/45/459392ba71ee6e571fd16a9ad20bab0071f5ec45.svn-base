<?page title="new page title" contentType="text/html;charset=UTF-8"?>
<zk xmlns:n="client">
	<window  title="" border="none" use="com.tepsa.sisvyr.view.ctrl.WndTipoItinerario">
		<div id="divLista">
			<listbox id="listboxLista">
				<listhead sizable="true">
					<listheader width="50px" label="#" />
					<listheader label="DENOMINACION" sort="auto" />
					<listheader label="NOMBRE CORTO" sort="auto" />
				</listhead>
			</listbox>
		</div>
		
		<div id="divMantenimiento">
			<groupbox closable="false" mold="3d">
			<caption label="DATOS TIPO ITINERARIO" />
			<grid>
				<columns>
					<column  width="120px" align="right"/>
					<column  width="250px"/>
					<column  width="100px" align="right"/>
				</columns>
				<rows>
					<row>
						<label value="DENOMINACIÓN (*) :"  />
						<div>
							<textbox id="textboxId"/>
							<textbox id="txtDenominacion"  maxlength="30" onOK="com.tepsa.sisvyr.service.util.Util.setFocus(txtNombreCorto)" />
						</div>
						<label value="NOMBRE CORTO (*) :" />
						<textbox id="txtNombreCorto"  maxlength="15"/>
					</row>
				</rows>
			</grid>
			</groupbox>
		</div>
		
	</window>
</zk>