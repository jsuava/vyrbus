package com.tepsa.sisvyr.service.util;

import org.jasypt.encryption.pbe.StandardPBEStringEncryptor;
import org.jasypt.util.text.BasicTextEncryptor;

public class Encriptar {
	/**
	 * Codifica una cadena de caracteres de entrada
	 * @param password
	 * @param key
	 * @return Cadena de caracteres codificado
	 * @throws Exception
	 */
	static public String codifica(String password, String key)throws Exception {
		try {
			BasicTextEncryptor textEncryptor = new BasicTextEncryptor();
			textEncryptor.setPassword(key);
			String encryptedText = textEncryptor.encrypt(password);
			return encryptedText;
		}catch (Exception ex) {
			throw new Exception(ex);
		}
	}

	/**
	 * Decodifica una cadena de caracteres codificado de entrada
	 * @param password
	 * @param key
	 * @return cadena de caracteres
	 * @throws Exception
	 */
	static public String decodifica(String password, String key) {
		String Text = null;
		try {
			BasicTextEncryptor textEncryptor = new BasicTextEncryptor();
			textEncryptor.setPassword(key);
			Text = textEncryptor.decrypt(password);
//			ejemplo();
			
		}catch (Exception ex) {
			ex.printStackTrace();
//			throw new Exception(ex);
		}
		return Text;
	}
	
	static public String decodificaByAlgorithm(String password, String key)throws Exception {
		try {
			StandardPBEStringEncryptor textEncryptor = new StandardPBEStringEncryptor();
			textEncryptor.setAlgorithm("PBEWithMD5AndDES");
			textEncryptor.setPassword(key);
			String Text = textEncryptor.decrypt(password.substring(4,password.length()-1));
			return Text;
		}catch (Exception ex) {
			throw new Exception(ex);
		}
	}
	
	static public void ejemplo(){
		String login = "moscco";
		String pwd = "tepsac";
		try{
			String cod = codifica(pwd, login);
			System.out.println(cod);
		}catch(Exception ex){
			ex.printStackTrace();
		}
	}
}