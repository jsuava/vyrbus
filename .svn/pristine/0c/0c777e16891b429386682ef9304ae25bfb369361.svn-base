//		if(getObjetoConfirmar().getRuta().getId().intValue()!=ventaOriginal.getRuta().getId().intValue() && dblImporte.getValue()==0.0){
//			dblImporte.setValue(Constantes.PENALIDAD_REIMPRESION);
//			onLoadEspecieValorada();
//		}
//	}
}
