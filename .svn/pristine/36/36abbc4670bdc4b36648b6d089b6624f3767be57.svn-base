	public boolean addEventListener(String evtnm, EventListener<? extends Event> listener) {
		boolean resultadoEvento = true;

		if (evtnm.equals(com.tepsa.sisvyr.view.ui.Events.ON_SELECT)) {
			oEventListenerFilter = listener;
		}else if(evtnm.equals(com.tepsa.sisvyr.view.ui.Events.ON_OK)){
			oEventListenerFilter = listener;
		}else {
			resultadoEvento = super.addEventListener(evtnm, listener);
		}

		return resultadoEvento;
	}

