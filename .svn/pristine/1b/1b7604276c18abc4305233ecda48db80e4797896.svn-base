import com.tepsa.sisvyr.service.exceptions.CancelaGrabacionException;
import com.tepsa.sisvyr.service.exceptions.CantidadTrabajadoresNullException;
import com.tepsa.sisvyr.service.exceptions.MailIncorectoException;
import com.tepsa.sisvyr.service.exceptions.NumeroDocumentoIncorrectoException;
import com.tepsa.sisvyr.service.exceptions.NumeroDocumentoNullException;
import com.tepsa.sisvyr.service.exceptions.RazonSocialDuplicadoException;
import com.tepsa.sisvyr.service.exceptions.RazonSocialNullException;
import com.tepsa.sisvyr.service.exceptions.RucDuplicadoException;
import com.tepsa.sisvyr.service.exceptions.UbigeoNullException;
