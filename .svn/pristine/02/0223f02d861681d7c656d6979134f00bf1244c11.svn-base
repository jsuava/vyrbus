package com.tepsa.sisvyr.service.exceptions;

/**
 * @author Jose
 *
 */
public class PromocionExcepcion extends Exception {
	public static final long serialVersionUID = 1L;
	public static final int DENOMINACION = 1;
	public static final int TIPO_DESCUENTO = 2;
	public static final int NO_DESCUENTO = 3;
	public static final int NO_DESCUENTO_IMPORTE = 4;
	public static final int DESCUENTO_IMPORTE = 5;
	public static final int DENOMINACION_DUPLICADA = 6;
	
	private Integer tipo;

	public PromocionExcepcion() {
		super();
		// TODO Auto-generated constructor stub
	}

	public PromocionExcepcion(Integer tipo) {
		super();
		this.tipo = tipo;
	}

	/**
	 * @return the tipo
	 */
	public Integer getTipo() {
		return tipo;
	}

	/**
	 * @param tipo the tipo to set
	 */
	public void setTipo(Integer tipo) {
		this.tipo = tipo;
	}
}
