		lbl12=(Label)this.getFellow("lbl12");
		lbl13=(Label)this.getFellow("lbl13");
		lbl14=(Label)this.getFellow("lbl14");
		lbl15=(Label)this.getFellow("lbl15");
		lbl16=(Label)this.getFellow("lbl16");
		lbl17=(Label)this.getFellow("lbl17");
