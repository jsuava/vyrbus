		lstbxTipoMovimiento=(Listbox)this.getFellow("lstbxTipoMovimiento");
		cmbFormaPago=(Combobox)this.getFellow("cmbFormaPago");
		lstbxVentasPuntoVenta=(Listbox)this.getFellow("lstbxVentasPuntoVenta");
		rdContabilizar=(Radio)this.getFellow("rdContabilizar");
		rdSumarImportes=(Radio)this.getFellow("rdSumarImportes");
		frzVentasPuntoVenta=(Frozen)this.getFellow("frzVentasPuntoVenta");
		lbl8=(Label)this.getFellow("lbl8");
