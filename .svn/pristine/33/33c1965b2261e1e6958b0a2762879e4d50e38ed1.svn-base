<?page title="new page title" contentType="text/html;charset=UTF-8"?>
<zk>
<window id="wndAprobarCredito"  border="none" use="com.tepsa.sisvyr.view.ctrl.WndAprobarLineaCreditoN2" width="810px">
<panel title="::: APROBACIÓN LINEA DE CRÉDITO - FINANZAS :::" framable="true" width="805px" border="normal" closable="true" onClose="wndAprobarCredito.closeTabWindow()">
	<panelchildren>
	
	<tabbox>
		<tabs>
			<tab id="tabPendientes" label="Solicitudes Pendientes" />
			<tab id="tabHistorial" label="Solicitudes Aprobadas y/o Desaprobadas" />
		</tabs>
		<tabpanels>
			<tabpanel>
				<grid id="grdAprobBusqCliente">
					<columns>
						<column width="80px"/>
						<column />
					</columns>
					<rows>
						<row>
							<label value="Cliente" sclass="label-size11-bold"/>
							<hbox>
								<combobox id="cmbCliente" readonly="true" width="220px" /><separator width="15px" />
								<button id="btnBuscar" label="Buscar" onClick="wndAprobarCredito.listPendientes()" tooltiptext="Actualizar solicitudes pendientes por aprobar" image="/resources/mp_buscarEnabled.png" style="cursor:pointer" />
							</hbox>
						</row>
					</rows>
				</grid>
				
				<separator height="1px" />
				<listbox id="listPendientes" mold="paging" rows="10" >
					<listhead >
						<listheader label="#" width="30px" />
						<listheader label="F.SOLICITUD" width="70px" sort="auto" tooltiptext="Fecha de la Solicitud"/>
						<listheader label="FUNCIONARIO" width="180px" sort="auto" />
						<listheader label="RUC" width="85px" sort="auto"/>
						<listheader label="RAZÓN SOCIAL" width="220px" sort="auto"/>
						<listheader label="C.SOLICITADO" width="80px" align="right" sort="auto" tooltiptext="Crédito Solicitado"/>
						<listheader label="VER SOLICITUD" />
					</listhead>
				</listbox>
		
				<groupbox id="grbSolicitud" style="border:none">
					<groupbox style="border:none" closable="false" mold="3d">
						<caption label="DATOS DE LA SOLICITUD" />
						<grid id="grCliente" style="border:none">
							<columns>
								<column width="115px"  align="right"/>
								<column width="117px" />
								<column width="90px" align="right"/>
							</columns>
							<rows>
								<row>
									<label value="NÚMERO RUC :"  />
									<label  id="lblRuc" style="color:blue;font-size:11px !important" />
									<label value="RAZÓN SOCIAL :" />
									<label  id="lblRazonSocial" style="color:blue" />
								</row>
								<row id="rowCreditoAnterior" >
									<label value="CRÉDITO ANTERIOR :"  />
									<label  id="lblCreditoAnterior" style="color:blue;font-size:11px !important" />
									<separator/><separator/>
								</row>
								<row>
									<label value="FECHA SOLICITUD :" />
									<label  id="lblFechaSolicitud" style="color:blue;font-size:11px !important" />
									<label value="FUNCIONARIO :" />
									<label  id="lblFuncionario" style="color:blue" />
								</row>
								<row>	
									<label value="CRÉDITO SOLICITADO :"  />
									<label  id="lblCreditoSolicitado" style="color:blue;font-size:11px !important" />
									<label value="% SOBREGIRO :"  />
									<hbox align="center">
										<label  id="lblSobregiro"  style="color:blue;font-size:11px !important"/>
										<label  id="lblMontoSobregiro" style="color:blue;font-size:11px !important"/>
									</hbox>
								</row>
								<row spans="1,3">
									<separator />
									<hbox align="center">
										<checkbox  id="chbesCanje" checked="false" disabled="true" />
										<label value="CANJE" style="cursor:default;font-weight: bold"/>
										<separator width="70px" />
										<checkbox id="chbEsAmpliacion" checked="false" disabled="true" />
										<label id="lblAmpliacion" value="AMPLIACIÓN"  style="cursor:default;font-weight: bold"/>
									</hbox>
								</row>	
							</rows>
						</grid>
					</groupbox>
					<separator height="1px" />
					
					<groupbox style="border:none" closable="false" mold="3d">
						<caption label="APROBACIÓN LINEA DE CRÉDITO " />
						<grid style="border:none">
							<columns>
								<column width="115px"/>
							</columns>
							<rows>
								<row>
									<hbox>
										<radio id="rbAprueba" label="Aprobar" style="color:blue" onCheck="if(rbAprueba.isChecked()) rbDesaprueba.setChecked(false);if(rbAprueba.isChecked()) chbModificarCredito.setDisabled(false);if(rbAprueba.isChecked()) txtMotivo.setReadonly(true);if(rbAprueba.isChecked()) dbxCreditoAprobado.setValue(dbxCreditoSolcitado.getValue()); "/>
									</hbox>
									<hbox align="center">
										<label value="Credito Aprobado" sclass="label-size11-bold" /><separator width="10px" />
										<doublebox id="dbxCreditoAprobado" onChange="wndAprobarCredito.onChangeSobregiro()" format="#,##0.00" width="80px" focus="true" />
										<checkbox id="chbModificarCredito" label="Modificar" checked="false" onCheck="if(chbModificarCredito.isChecked()) dbxCreditoAprobado.setReadonly(false);if(chbModificarCredito.isChecked()) dbxCreditoAprobado.setFocus(true);if(!(chbModificarCredito.isChecked())) dbxCreditoAprobado.setReadonly(true); "/>
										<space width="25px" /> <label value="Tipo Combranza" sclass="label-size11-bold"/>
										<combobox id="cmbTipoCombranza" readonly="true" width="100px" />																												 
									</hbox>
								</row>
								<row>
									<hbox>
										<radio id="rbDesaprueba" label="Desaprobar" style="color:red"  onCheck="if(rbDesaprueba.isChecked()) rbAprueba.setChecked(false);if(rbDesaprueba.isChecked()) txtMotivo.setReadonly(false);if(rbDesaprueba.isChecked()) txtMotivo.setFocus(true);if(rbDesaprueba.isChecked()) dbxCreditoAprobado.setReadonly(true);if(rbDesaprueba.isChecked()) dbxCreditoAprobado.setText(null);if(rbDesaprueba.isChecked()) chbModificarCredito.setDisabled(true);" />
									</hbox>
									<hbox align="end">
										<label value="Motivo desaprueba" sclass="label-size11-bold"/><separator width="2px" />
										<textbox id="txtMotivo" readonly="true" width="285px"/>
									</hbox>																																	
								</row>
								<row>
									<label value="Observaciones" sclass="label-size11-bold"  />
									<textbox id="txtObservaciones" width="400px" readonly="false" />
								</row>
							</rows>
						</grid>
					</groupbox>	
					<separator height="2px"/>
					<div align="center">
						<hbox>
							<button id="btnCancelar" label="Cancelar" onClick="wndAprobarCredito.onClickCancelar()" tooltiptext="Cancelar Aprobanción"  image="/resources/mp_cancelarEnabled.png" style="cursor:pointer" />
							<separator width="10px" />
							<button id="btnAceptar" label="Aceptar" onClick="wndAprobarCredito.onClickAceptar()" tooltiptext="Aprobar Solicutud"  image="/resources/mp_aceptarEnabled.png" style="cursor:pointer" />
						</hbox>
					</div>
				</groupbox>	
			</tabpanel>
			
			<tabpanel>
				<grid>
					<columns>
						<column width="110px"/>
						<column width="150px"/>
						<column width="70px"/>
						<column />
					</columns>		
					<rows>
						<row>
							<label value="Fecha Inicio" sclass="label-size11-bold" />
							<datebox id="dtxFechaInicio" format="dd/MM/yyyy" />
							<label value="Fecha Final" sclass="label-size11-bold" />
							<hbox align="center">
								<datebox id="dtxFechaFinal" format="dd/MM/yyyy" /><separator width="20px" />
								<button id="btnBuscarSolApro" label="Buscar" onClick="wndAprobarCredito.listHistorial()"  image="/resources/mp_buscarEnabled.png" style="cursor:pointer" />
							</hbox>
							
						</row>
						<row>
							<label value="Estado Solicitud" sclass="label-size11-bold" />
							<combobox id="cmbEstadoSolicitud"  readonly="true"/>
							<label value="Cliente" sclass="label-size11-bold"/>
							<combobox id="cmbclienteHist" readonly="true" width="210px" />
														
						</row>
					</rows>
				</grid>
				
					
				
				<separator height="4px" />
				<listbox id="listHistSolicitudes" mold="paging" rows="10" >
					<listhead >
						<listheader label="#" width="30px" />
						<listheader label="FUNCIONARIO" width="180px" sort="auto" />
						<listheader label="CLIENTE" width="200px" sort="auto"/>
						<listheader label="F. SOLICITUD" width="75px" sort="auto" tooltiptext="Fecha de la Solicitud"/>
						<listheader label="F. APROBACIÓN" width="100px" sort="auto" tooltiptext="Fecha de Aprobación"/>
						<listheader label="ESTADO " width="90px" sort="auto" tooltiptext="Estado Credito"/>
					</listhead>
				</listbox>	
			</tabpanel>
		</tabpanels>
	</tabbox>
<!-- 	<div align="right"> -->
<!-- 		<button label="Cerrar" tooltiptext="Cerra ventana." image="resources/mp_cerrar.png" style="cursor:pointer" onClick="wndAprobarCredito.closeTabWindow()"/> -->
<!-- 	</div> -->
	</panelchildren>
</panel>
</window>
</zk>
