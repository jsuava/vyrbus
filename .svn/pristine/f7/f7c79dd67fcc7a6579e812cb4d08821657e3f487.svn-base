<?page title="" contentType="text/html;charset=UTF-8"?>
<zk>
<window id="wndComprobantesSinBoleto" border="none" use="com.tepsa.sisvyr.view.ctrl.WndComprobantesSinBoleto" contentStyle="overflow:auto" >
	<tabbox mold="accordion-lite">
		<tabs width="100%">
			<tab id="tabListado" label="RELACION DE COMPROBANTES SIN BOLETO"/>
		</tabs>
		<tabpanels width="100%">
<!-- 			<tabpanel style="overflow:auto;"> -->
			<tabpanel style="overflow:auto;">
				<vbox>
					<hbox align="center" >
						<toolbar width="1548px">
							<label value="TIPO DE COMPROBANTE : " />
							<combobox id="cmbTipoComprobanteBusq" width="150px" readonly="true"/>
							<space width="10px"/>
							<label value="AGENCIA :"/>
							<combobox id="cmbAgencia" width="200px"/>
<!-- 						<space width="5px"/> -->
<!-- 						<toolbar width="945px"> -->
							<space width="5px"/>
							<button label="Actualizar" mold="trendy" autodisable="self" image="resources/mp_refrescarEnabled.png" onClick="wndComprobantesSinBoleto.buscarComprobantes()" height="27px"/>
							<button label="Cerrar" mold="trendy" image="resources/mp_cerrarEnabled.png" onClick="wndComprobantesSinBoleto.closeTabWindow()" height="27px" width="85px"/>
						</toolbar>
					</hbox>					
					<listbox id="lbxComprobantes" width="100%"  mold="paging" pageSize="15">
						<listhead>
							<listheader label="PTO EMBARQUE" width="120px"/>
							<listheader label="COMPROBANTE" width="140px"/>
							<listheader label="N°COMPROBANTE" width="100px"/>
							<listheader label="NRO CONTROL" width="95px"/>
							<listheader label="ASIENTO" width="60px"/>
							<listheader label="FPARTIDA" width="60px"/>
							<listheader label="HPARTIDA" width="55px"/>
							<listheader label="RUC" width="60px"/>
							<listheader label="RAZON SOCIAL" width="140px"/>
							<listheader label="DNI" width="65px"/>
							<listheader label="PASAJERO" width="150px"/>
							<listheader label="RUTA" width="120px"/>
							<listheader label="REPVENTA" width="120px"/>
							<listheader label="AGENCIA" width="120px"/>
							<listheader label="FECHA VENTA" width="100px"/>						
						</listhead>
					</listbox>
				</vbox>
			</tabpanel>
		</tabpanels>
	</tabbox>
</window>
</zk>