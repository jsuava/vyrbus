<?page title="" contentType="text/html;charset=UTF-8"?>
<zk>
<window title="" border="none"  use="com.tepsa.sisvyr.view.ctrl.WndEstadoDocumentoBus">
   <div id="divLista">
		<listbox id="listboxLista">
			<listhead sizable="true">
				<listheader label="#" width="50px" />
				<listheader label="DENOMINACION" sort="auto" />
				<listheader label="CODIGO" sort="auto" />
				<listheader label="TIPO ESTADO" sort="auto" />
			</listhead>
		</listbox>
	</div>
	<div id="divMantenimiento">
		<groupbox mold="3d" closable="false">
			<caption label="Datos" />
			<grid>
				<columns>
					<column width="100px" align="right" />
					<column width="240px" />
					<column width="50px" align="right"/>
				</columns>
				<rows>
					<row>
						<div>
							<label value="DENOMINACIÓN (*) :" />
							<textbox id="textboxId" />
						</div>
						<textbox id="txtdenominacion"  maxlength="50" onOK="txtcodigo.setFocus(true)"/>
						<label value="CÓDIGO :" />
						<textbox id="txtcodigo"  maxlength="10" width="100px" onOK="cbotipoEstado.setFocus(true); cbotipoEstado.select()"/>
					</row>
					<row>
						<label value="TIPO ESTADO (*) :" />
						<combobox id="cbotipoEstado" readonly="true" />
						<separator></separator><separator></separator>
					</row>
				</rows>
			</grid>
		</groupbox>
	</div>	
</window>
</zk>