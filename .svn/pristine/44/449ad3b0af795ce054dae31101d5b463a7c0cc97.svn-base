<?page title="" contentType="text/html;charset=UTF-8"?>
<zk>
<window id="wndDiarioAcumulado" title="" border="none" use="com.tepsa.sisvyr.view.ctrl.WndRptDiarioAcumulado">
	<grid>
		<columns>
			<column width="80px" />
			<column width="190px"/>
			<column width="100px"/>
			<column width="150px"/>
			<column width="92px"/>
		</columns>
		<rows>
			<row>
				<label value="Fecha Inicial" sclass="label-size11-bold" />
				<datebox id="dbxFechaInicial" format="dd/MM/yyyy"/>
				
				<label value="Fecha Final" sclass="label-size11-bold" />
				<datebox id="dbxFechaFinal" format="dd/MM/yyyy"/>
				
				<separator />
				<separator />
			</row>
			<row>
				<label value="Servicio" sclass="label-size11-bold" />
				<combobox id="cmbServicio" readonly="true" />
				
				<label value="Ruta Itinerario" sclass="label-size11-bold" />
				<combobox id="cmbrutaItinerario" readonly="true" />
				
				<button label="Exportar"  image="/resources/mp_excel.png" onClick="wndDiarioAcumulado.exportarExcel()" />
				<separator />
			</row>
			<row>
				<separator/>
				<checkbox id="cbxCuadroIngresos" label="Mostrar cuadro de ingresos" />
				<checkbox id="cbxDetallado" label="Detallado" />
				<separator/>
				<button label="Buscar" width="80px" onClick="wndDiarioAcumulado.cargarDiarioAcumulado()"  image="/resources/mp_buscarEnabled.png"/>
				<button label="Cerrar"  image="/resources/mp_cerrar.png" onClick="wndDiarioAcumulado.closeTabWindow()"/>
			</row>
		</rows>
	</grid>
 	<separator height="2px" />
